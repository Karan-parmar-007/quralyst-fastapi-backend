# =============================================================================
# Quralyst Backend — .env.example
# Copy this file to .env and fill in the real values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=Quralyst
MONGO_DB_NAME=Quralyst_dev_2

# ── JWT / Auth ────────────────────────────────────────────────────────────────
SECRET_KEY=<your-very-long-random-secret-key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=15
FORGET_PASSWORD_TOKEN_EXPIRE_MINUTES=15
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=15
CSRF_SECRET_KEY=<optional-csrf-secret-falls-back-to-SECRET_KEY>
